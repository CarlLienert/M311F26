<paragraphs>
  <title>Classroom Expectations</title>
  <p>
    Please be respectful of your peers and your instructor:
    <ul>
      <li>
        <p>
          Be in class on time.
        </p>
      </li>
      <li>
        <p>
          Do not come and go during class.
        </p>
      </li>
      <li>
        <p>
          Put your phone away.
        </p>
      </li>
    </ul>
  </p>
  
</paragraphs>
</section>